<section class="aero-hero" data-section-id="{{ section.id }}">
  <div class="aero-hero__content">
    <div class="aero-reveal">
      <span class="aero-hero__meta">{{ section.settings.subtitle }}</span>
    </div>
    
    <h1 class="aero-hero__title aero-reveal" style="transition-delay: 0.1s;">
      {{ section.settings.title }}
    </h1>
    
    <div class="aero-reveal" style="transition-delay: 0.2s;">
      <a href="{{ section.settings.btn_link | default: '#' }}" class="aero-btn">
        {{ section.settings.btn | default: 'DISCOVER COLLECTION' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aero Hero",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "WEIGHTLESS\nFORM"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "SS26 OPTIC SYSTEM"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text",
      "default": "VIEW EDITORIAL"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Aero Hero"
    }
  ]
}
{% endschema %}
